-- 4. Query para ver tudo organizado (com formatação de tempo)
SELECT 
    a.titulo AS Album,
    m.titulo AS Musica,
    CONCAT(FLOOR(m.duracao_segundos/60), ':', LPAD(MOD(m.duracao_segundos,60), 2, '0')) AS Tempo
FROM musicas m
JOIN albuns a ON m.album_id = a.id
ORDER BY a.titulo, m.titulo;

